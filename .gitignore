.env
# .gitignore for .NET projects 9
# Basado en recomendaciones de Microsoft y GitHub

## === COMPILACIÓN Y BUILD ===
bin/
obj/
*.dll
*.exe
*.so
*.dylib
*.pdb
*.nativeimage

## === VISUAL STUDIO ===
# Archivos de usuario
*.user
*.suo
*.userosscache
*.sln.docstates
.vs/

# Cache y temporales
.vs/
.vscode/
*.user.config
.VisualStudio/

# Archivos de solución
*.sln.bak
*.csproj.bak

## === NUGET ===
# Paquetes
*.nupkg
*.snupkg
.nuget/

# Cache de NuGet
project.lock.json
project.fragment.lock.json
artifacts/
.nuget.props
.nuget.targets
.nuget.dgspec.json
.nuget.cache
.nuget.g.props
.nuget.g.targets

## === IDE Y EDITORES ===
# Rider
.idea/
*.sln.iml
*.DotSettings.user
.idea_modules/

# VS Code (opcional, descomenta si no quieres ignorarlo)
# .vscode/

# Sublime Text
*.sublime-workspace
*.sublime-project

# Vim
*.swp
*.swo
*~

## === TESTING ===
# Test Results
TestResults/
coverage/
*.trx
.coverage
OpenCover/

## === LOGS Y TEMPORALES ===
*.log
*.log.*
logs/
tmp/
temp/
*.tmp

## === CONFIGURACIÓN LOCAL ===
# Configuración de usuario y secretos
secrets.json
appsettings.Development.json
appsettings.local.json
local.settings.json
*.user.config
*.user.props

## === ANÁLISIS Y PROFILING ===
# ReSharper
_ReSharper*/
.ReSharper.user
*.resharper
*.resharper.user
.resharper/

# Coverlet
.coverletdata/

# Profiling
*.etl
*.vsp
*.vspx

## === DEPLOY Y PACKAGE ===
PublishProfiles/
publish/
dist/
release/

## === SISTEMA OPERATIVO ===
# macOS
.DS_Store
.AppleDouble
.LSOverride

# Windows
Thumbs.db
Desktop.ini
$RECYCLE.BIN/

# Linux
.directory

## === OTROS ===
# Archivos backup
*.bak
*.backup
*.orig

# Archivos temporales
*.tmp
*.temp
~*

# Visual Studio Code debug
.debug/

# .NET Core
*.runtimeconfig.json

# Local environment variables
.env
.env.local
.env.*.local

# Docker
.dockerignore
docker-compose.override.yml