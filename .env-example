# SqlServerMCP environment variables
# Copy and adjust for local development. Do NOT commit real secrets.

# Required if SQLSERVER_CONNECTION_STRING is not provided
SQLSERVER_PASSWORD=__CHANGE_ME__

# Optional connection parts
SQLSERVER_SERVER=localhost
SQLSERVER_DATABASE=Northwind
SQLSERVER_USER=sa

# Optional full connection string (takes precedence)
# SQLSERVER_CONNECTION_STRING=Server=localhost;Database=Northwind;User Id=sa;Password=__CHANGE_ME__;Encrypt=Strict;TrustServerCertificate=False;

# Transport/security options
MCP_MODE=http
MCP_ENABLE_LEGACY_SSE=false

# Optional sanitized debug details in MCP errors (recommended only for local development)
MCP_INCLUDE_DEBUG_DETAILS=false

# Optional HTTP auth for remote/local HTTP transport.
# - Leave MCP_HTTP_AUTH_ENABLED=false to run without auth.
# - Set MCP_HTTP_AUTH_ENABLED=true and MCP_AUTH_TOKEN to require a token.
# - Clients may send either Authorization: Bearer <token> or the custom header below.
MCP_HTTP_AUTH_ENABLED=false
# MCP_AUTH_TOKEN=__CHANGE_ME__
MCP_AUTH_HEADER_NAME=X-MCP-Auth

# SQL Server encryption defaults
SQLSERVER_ENCRYPT=Mandatory
SQLSERVER_TRUST_SERVER_CERTIFICATE=true
SQLSERVER_CONNECT_TIMEOUT=30

# Troubleshooting local SQL Server TLS/SSL:
# - For local/dev instances, `Mandatory + true` is usually the best compatibility balance.
# - `Strict` requires newer server/TDS/TLS support and may fail before login on older local instances.
# - For production, prefer `Mandatory` or `Strict` with `SQLSERVER_TRUST_SERVER_CERTIFICATE=false`
#   and a valid certificate installed on the SQL Server instance.

# Query guardrails
MCP_QUERY_MAX_ROWS=1000
MCP_QUERY_TIMEOUT_SECONDS=30

# Metadata cache (TTL seconds)
MCP_METADATA_CACHE_TTL_SECONDS=60

# Query rate limiting (fixed window)
MCP_QUERY_RATE_LIMIT_MAX_REQUESTS=30
MCP_QUERY_RATE_LIMIT_WINDOW_SECONDS=60

# Audit log in-memory retention
MCP_AUDIT_MAX_ENTRIES=1000
